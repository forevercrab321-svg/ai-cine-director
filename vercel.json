{
    "framework": "vite",
    "buildCommand": "vite build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "rewrites": [
        { "source": "/api/:path*", "destination": "/api/index.ts" }
    ],
    "functions": {
        "api/index.ts": {
            "maxDuration": 300
        }
    }
}
