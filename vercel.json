{
        "framework": "vite",
        "buildCommand": "node scripts/bundle-api.mjs && vite build",
        "outputDirectory": "dist",
        "installCommand": "npm install",
        "rewrites": [
                    { "source": "/api/:path*", "destination": "/api/bundle.cjs" }
        ],
        "functions": {
                    "api/bundle.cjs": {
                                    "maxDuration": 300
                    }
        }
}
