{
    "framework": "vite",
    "buildCommand": "vite build && node scripts/bundle-api.mjs",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "rewrites": [
        { "source": "/api/:path*", "destination": "/api/bundle.cjs" }
    ],
    "functions": {
        "api/bundle.cjs": {
            "maxDuration": 300
        }
    }
}
